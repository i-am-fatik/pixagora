# Local (Next.js)
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211
CONVEX_DEPLOYMENT=anonymous:anonymous-pixagora

# Convex backend env (set via `npx convex env set`, not read from .env.local)
PIXAGORA_WEBHOOK_SECRET=change-me
PIXAGORA_WEBHOOK_DRY_RUN=false
RESEND_API_KEY=change-me
PIXAGORA_EMAIL_FROM="Svobodny pristav <onboarding@resend.dev>"
PIXAGORA_EMAIL_LOGO_URL=https://pristav.urza.cz/img/urza.logo.dark.128x115.png
PIXAGORA_EMAIL_BRAND_NAME="Svobodny pristav"
PIXAGORA_EMAIL_PRODUCT_NAME=Pixagora
PIXAGORA_EMAIL_LOGO_ALT="Svobodny pristav"
PIXAGORA_EMAIL_REPLY_TO=urzanarchy@gmail.com

# Poller env
PIXAGORA_WEBHOOK_URL=http://127.0.0.1:3211/api/webhooks/startovac-poller

# Production (self-hosted backend)
# CONVEX_SELF_HOSTED_ADMIN_KEY=
